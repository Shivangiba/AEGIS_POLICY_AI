GROQ_API_KEY="your_groq_api_key_here"
EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# ALLOWED_ORIGINS — comma-separated list of browser origins (scheme + host + port)
# that FastAPI's CORS middleware will accept requests from.
#
# The backend always allows localhost:3000, 127.0.0.1:3000, and 0.0.0.0:3000
# in code (main.py), so those never need to appear here.
#
# Only add entries here if you need to allow additional origins, e.g.:
#   - A deployed frontend URL: "https://your-app.example.com"
#   - A specific LAN IP (not recommended; use the hardcoded list in main.py instead)
#
# Default (covers all standard local dev cases):
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://0.0.0.0:3000"
